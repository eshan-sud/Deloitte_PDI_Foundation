pipeline {
    agent any

    environment {
        APP_NAME = "demo-app"
        BUILD_NUMBER_VAR = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                echo 'Source Code Repository: Ready'
            }
        }

        stage('Build') {
            steps {
                echo 'Building the application...'
                echo "Building ${APP_NAME} - Build #${BUILD_NUMBER_VAR}"
                bat 'echo Build process completed'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
                bat 'echo Running unit tests'
                bat 'echo All tests passed'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                echo "Deploying ${APP_NAME} to staging environment"
                bat 'echo Deployment successful'
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully'
        }
        failure {
            echo 'Pipeline failed'
        }
    }
}